#!/usr/bin/env bash
# Installs and configures HAProxy to load balance traffic between web-01 and web-02

# Update packages and install HAProxy
sudo apt-get update -y
sudo apt-get install haproxy -y

# Enable HAProxy to be managed via an init script
sudo sed -i "s/ENABLED=0/ENABLED=1/" /etc/default/haproxy

# Configure HAProxy with the roundrobin algorithm and backend servers
sudo cat << 'HAPROXY' >> /etc/haproxy/haproxy.cfg

frontend alu_frontend
    bind *:80
    mode http
    default_backend alu_backend

backend alu_backend
    balance roundrobin
    mode http
    server 7112-web-01 34.237.242.75:80 check
    server 7112-web-02 32.198.91.240:80 check
HAPROXY

# Restart HAProxy to apply changes
sudo service haproxy restart
