#!/usr/bin/env bash
# Configures Nginx with a 301 redirect and a custom 404 error page

# Update and install Nginx
apt-get -y update
apt-get -y install nginx

# Create the standard index page
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Create the custom 404 error page
echo "Ceci n'est pas une page" > /var/www/html/404.html

# Inject the 301 redirect and custom 404 configuration into the server block
sed -i '/server_name _;/a \ \tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}\n\n\terror_page 404 /404.html;\n\tlocation = /404.html {\n\t\troot /var/www/html;\n\t\tinternal;\n\t}' /etc/nginx/sites-available/default

# Restart Nginx safely
service nginx restart
