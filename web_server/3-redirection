#!/usr/bin/env bash
# Configures Nginx to permanently redirect /redirect_me requests

# Update package list and install Nginx if not already installed
apt-get -y update
apt-get -y install nginx

# Overwrite default homepage string from task 1
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Insert the 301 redirect rule inside the default Nginx configuration
# This searches for 'server_name _;' and inserts the rewrite rule below it
sed -i '/server_name _;/a \\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}' /etc/etc/nginx/sites-available/default 2>/dev/null || \
sed -i '/server_name _;/a \\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}' /etc/nginx/sites-available/default

# Restart Nginx safely without using systemctl
service nginx restart
